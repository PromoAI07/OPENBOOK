# Copy this file to .env and adjust as needed. Never commit your real .env.
# All values are optional; sensible defaults are used when unset.

# Port the server listens on.
PORT=3000

# Set to "production" when deployed behind HTTPS. This turns on the Secure
# flag for the session cookie.
# NODE_ENV=production

# Folder where the database (openbook.db) and uploaded images are stored.
# In production, point this at a mounted persistent volume so data survives
# restarts and redeploys, e.g. DATA_DIR=/data
# DATA_DIR=

# --- Logging ---
# Verbosity: trace | debug | info | warn | error | fatal.
# Default: info in production, debug in development.
# LOG_LEVEL=info
# A DB query taking at least this many ms is logged as a "slow query" (default 100).
# DB_SLOW_MS=100

# --- Email (Resend). Powers verification emails AND password-reset emails. ---
# Set RESEND_API_KEY to enable sending (free tier is plenty). EMAIL_FROM must be
# a sender on a domain you have verified in Resend (e.g. noreply@openbook.space).
# RESEND_API_KEY=
# EMAIL_FROM=OpenBook <noreply@openbook.space>
# Force new signups to verify their email before they can post. Default off, so
# password reset can work without adding signup friction. Set to 1 to require it.
# REQUIRE_EMAIL_VERIFICATION=0

# --- Platform admins (comma-separated emails) and Support page links ---
# ADMIN_EMAILS=you@example.com
# SUPPORT_GITHUB=
# SUPPORT_OPENCOLLECTIVE=
# SUPPORT_CRYPTO=

# --- Supporter payments (no Stripe; see PAYMENTS.md). Both rails are optional. ---
# PayPal rail: the email of the PayPal account that receives the money. Setting
# this turns the "Pay with PayPal" buttons on. Tiers auto-grant from PayPal's IPN
# posted to /api/webhooks/paypal.
# PAYPAL_RECEIVER_EMAIL=
# PAYPAL_ENV=live            # set to "sandbox" while testing with a sandbox account
# USDT rail: reuse SUPPORT_CRYPTO above as the USDT (TRC-20) deposit address.
# Supporters paste their tx hash; it is verified on-chain via TronGrid.
# TRON_API_KEY=              # optional, raises TronGrid rate limits
# TRON_API_BASE=https://api.trongrid.io
# USDT_TRON_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
# Charge amounts (the $1/$3 tiers are billed yearly in advance, $10 monthly).
# PRICE_SUPPORTER_YEAR=12
# PRICE_PLUS_YEAR=36
# PRICE_PREMIUM_MONTH=10
# Tests only: bypass PayPal/TronGrid verification so smoke tests can run offline.
# BILLING_TEST_MODE=0

# --- Phase 5: anti-sybil ---
# Signup proof-of-work: set to 0 to disable; difficulty is leading hex zeros
# (4 is about 65k hashes, well under 100ms in the browser).
# SIGNUP_POW=1
# SIGNUP_POW_DIFFICULTY=4
# Stable secret for signing proof-of-work challenges. Optional; a random one is
# used per boot if unset (fine for a single instance). Set it for multi-instance.
# POW_SECRET=
# Minimum trust level required to cast a downvote (0 = anyone, default 1).
# MIN_DOWNVOTE_TL=1
# Extra disposable-email domains to block (comma separated), added to the built-in list.
# DISPOSABLE_EMAIL_DOMAINS=
# Optional Cloudflare Turnstile CAPTCHA on signup (off unless the secret is set).
# TURNSTILE_SECRET=
# Background vote-ring scan: set to 0 to disable; interval in ms (default 30 min).
# SYBIL_JOB=1
# SYBIL_JOB_MS=1800000
